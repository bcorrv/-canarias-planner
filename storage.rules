rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }
    function userEmail() {
      return request.auth.token.email;
    }
    function isPlatformAdmin() {
      return signedIn() && userEmail() in ['bo.cverdugo@gmail.com'];
    }

    match /trips/{tripId}/documents/{documentId}/{fileName} {
      allow read, write: if signedIn();
    }

    match /users/{userId}/privateDocuments/{documentId}/{fileName} {
      allow read, write: if signedIn() && (request.auth.uid == userId || isPlatformAdmin());
    }
  }
}
